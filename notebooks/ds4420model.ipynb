    "import pandas as pd\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "data = pd.read_csv(\"spotifydataset.csv\")\n",
    "\n",
    "X = data[['danceability','energy','tempo']]\n",
    "y = data['popularity']\n",
    "\n",
    "model = LinearRegression()\n",
    "model.fit(X,y)\n",
    "\n",
    "print(\" trained successfully\")"
   ]
